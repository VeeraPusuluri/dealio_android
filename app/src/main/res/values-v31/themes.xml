<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      API 31+ overrides the mandatory system splash so it no longer shows the
      launcher icon as a separate first screen. It becomes a plain navy frame
      that flows straight into the branded Compose SplashScreen — one splash, not two.
    -->
    <style name="Theme.Dealio" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/dealio_navy_deep</item>
        <item name="android:statusBarColor">@color/dealio_navy_deep</item>
        <item name="android:navigationBarColor">@color/dealio_navy_deep</item>
        <item name="android:windowSplashScreenBackground">@color/dealio_navy_deep</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_icon_transparent</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@color/dealio_navy_deep</item>
    </style>
</resources>
